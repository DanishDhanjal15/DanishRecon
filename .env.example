# CyberRecon-Pro Environment Configuration
# Copy this file to .env and fill in your actual values

# GEMINI API KEY (for AI-powered vulnerability analysis)
# Get your free API key from: https://ai.google.dev/
# Free tier includes 15 requests/minute and ~1M tokens/month
GEMINI_API_KEY=your_api_key_here

# Optional: Gemini Model Selection
# Options: gemini-1.5-flash (fast, cheapvpc), gemini-1.5-pro (more detailed)
GEMINI_MODEL=gemini-1.5-flash

# Optional: Enable/disable features
ENABLE_GEMINI_ANALYSIS=true
ENABLE_CACHING=true
